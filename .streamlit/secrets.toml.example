# Streamlit Cloud Secrets (TOML)
# Paste this into: App → Settings → Secrets
# Replace placeholder values with your real API keys. Do not commit real keys.
# Changes take around a minute to propagate.
# Docs: https://docs.streamlit.io/streamlit-community-cloud/deploy-your-app/secrets-management

GROQ_API_KEY = "gsk_your_groq_key_here"
# Optional — only if you use OpenAI or Gemini in the sidebar:
# OPENAI_API_KEY = "sk-your_openai_key_here"
# GEMINI_API_KEY = "your_gemini_key_here"
